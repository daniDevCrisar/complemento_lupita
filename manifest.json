{
  "manifest_version": 3,
  "name": "Pedro Sotelo - ARRIBOS CRISAR",
  "version": "1.0",
  "description": "para ingreso a cargas , historial de viajes y mis cargas",

  "icons": {
    "16": "icons/icon.png"
  },


  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": ["activeTab"],
  
  "content_scripts": [
	  {
		"matches": [
      "*://efletexia.com/opl/confirmacion-ingreso-carga*","*://efletexia.com/operaciones/programar*"],
		"js": ["modulos/funciones_1.js",
          "modulos/variables.js",
          "content.js"
          ],
    "css": ["web_styles.css"]
	  }
  ]
}